# KameHouse Web - Variables de entorno
# Copia a .env.web y ajusta según tu entorno.

# Plataforma de ejecución: "desktop" o "web"
SEA_PUBLIC_PLATFORM="desktop"

# Puerto del backend Go para el proxy Rsbuild en desarrollo.
# Solo es necesario si el backend NO corre en el puerto 43211.
KAMEHOUSE_DEV_API_PORT=43211
