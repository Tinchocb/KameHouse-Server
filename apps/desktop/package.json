{
  "name": "kamehouse-desktop",
  "version": "0.1.0",
  "description": "Electron-based Desktop client for KameHouse",
  "main": "src/main.js",
  "author": "KameHouse",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder build",
    "build:mac": "electron-builder build --mac --arm64",
    "build:win": "electron-builder build --win --x64",
    "build:linux": "electron-builder build --linux --x64"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "mime-types": "^2.1.35",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "app.kamehouse.desktop",
    "productName": "KameHouse",
    "asar": true,
    "extraResources": [
      {
        "from": "binaries",
        "to": "binaries"
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "default",
          "arch": [
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true,
      "notarize": false,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "kamehouse-desktop-${version}_MacOS_${arch}.${ext}",
      "identity": "-"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "kamehouse-desktop-${version}_Windows_${arch}.${ext}",
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Entertainment",
      "artifactName": "kamehouse-desktop-${version}_Linux_${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "shortcutName": "KameHouse",
      "artifactName": "kamehouse-desktop-${version}_Windows_${arch}.${ext}",
      "perMachine": true
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "web/**/*",
      "assets/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ]
  },
  "private": true
}
