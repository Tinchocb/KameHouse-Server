# KameHouse Environment Variables
# Copy to .env and fill with your values. Do not commit .env.

# TMDB API Read Access Token (Bearer Token) — https://www.themoviedb.org/settings/api
KAMEHOUSE_TMDB_TOKEN=your_tmdb_bearer_token_here

# TMDB API Key (v3 auth)
KAMEHOUSE_TMDB_API_KEY=your_tmdb_api_key_here
