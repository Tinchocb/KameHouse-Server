func (c *CacheLayer) UpdateMediaListEntry(ctx context.Context, mediaID int, status *platform.MediaListStatus, scoreRaw *int, progress *int, startedAt *platform.FuzzyDateInput, completedAt *platform.FuzzyDateInput) (*platform.UnifiedMediaListEntry, error) {
	// Mutations require the API to be working
	if !IsWorking.Load() {
		return nil, fmt.Errorf("anilist cache: API client is not working, mutation operations are not available")
	}

	result, err := c.providerRef.Get().UpdateMediaListEntry(ctx, mediaID, status, scoreRaw, progress, startedAt, completedAt)
	c.checkAndUpdateWorkingState(err)

	// Invalidate relevant caches on successful mutation
	if err == nil {
		c.invalidateMediaCaches(mediaID)
		c.invalidateCollectionCaches()
	}

	return result, err
}


